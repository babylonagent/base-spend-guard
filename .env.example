# Base Spend Guard — runtime config (NEVER commit real values)
# Public Base RPC works for read-only simulation; use a private RPC for production.
BASE_RPC_URL=https://mainnet.base.org

# Path to your policy file (used by the MCP server)
SPENDGUARD_POLICY=./policy.json

# Optional: hex private key used ONLY to sign spend receipts.
# Keep this on your runtime host only. Never commit. Never put in client bundles.
SPENDGUARD_SIGNER_KEY=
