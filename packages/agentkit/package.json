{
  "name": "@spendguard/agentkit",
  "version": "0.1.0",
  "description": "Coinbase AgentKit ActionProvider for Base Spend Guard policy checks.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@spendguard/core": "0.1.0",
    "@spendguard/sdk": "0.1.0",
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "@coinbase/agentkit": ">=0.10.0"
  },
  "peerDependenciesMeta": {
    "@coinbase/agentkit": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
